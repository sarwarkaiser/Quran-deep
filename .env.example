# ============================================
# RCQI Platform - Environment Configuration
# ============================================

# --------------------------------------------
# Database Configuration (Supabase Recommended)
# --------------------------------------------

# Option 1: Supabase (Recommended for Production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Get this from Supabase Dashboard → Settings → Database → Connection string (URI)
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Option 2: Local PostgreSQL (Development)
# DATABASE_URL=postgresql://rcqi_user:rcqi_password@localhost:5432/rcqi

# --------------------------------------------
# Redis (Optional - for caching)
# --------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Meilisearch (Optional - for search)
# --------------------------------------------
MEILISEARCH_URL=http://localhost:7700
MEILI_MASTER_KEY=your-master-key-change-in-production

# --------------------------------------------
# LLM Provider (RCQI Analysis)
# --------------------------------------------
# Supported: anthropic | openai | openrouter | gemini | ollama | openai-compatible
LLM_PROVIDER=anthropic
# Optional global overrides
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=http://localhost:3010
OPENROUTER_APP_NAME=quran-deep

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# --------------------------------------------
# Authentication
# --------------------------------------------
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# --------------------------------------------
# API Server
# --------------------------------------------
API_PORT=3011
API_URL=http://localhost:3011

# --------------------------------------------
# Web App
# --------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3011
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# --------------------------------------------
# Environment
# --------------------------------------------
NODE_ENV=development
