{
    "name": "api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "lint": "eslint .",
        "smoke": "tsc --module commonjs --moduleResolution node --target es2022 --types node --esModuleInterop --skipLibCheck --outDir ./.smoke-dist src/smoke.ts && node ./.smoke-dist/smoke.js"
    },
    "dependencies": {
        "@fastify/cors": "8",
        "@rcqi/database": "workspace:*",
        "@rcqi/engine": "workspace:^",
        "@rcqi/shared": "workspace:*",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.29.1",
        "fastify": "^4.26.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^20.11.24",
        "eslint": "^8.57.0",
        "tsx": "^4.7.1",
        "typescript": "^5.3.3"
    }
}
